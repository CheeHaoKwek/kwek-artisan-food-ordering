# Port to run the express server on
PORT=3000

# Base URL for webhook button links
APP_URL=http://localhost:3000

# Secret key for Admin Dashboard sessions
JWT_SECRET=super_secret_artisan_key

# --- EMAIL REMINDER CONFIGURATION ---
# Provide your SMTP credentials below to enable automated email reminders upon order close.
# (e.g. For Gmail, use an App Password, not your regular account password)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
